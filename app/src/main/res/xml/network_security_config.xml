<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base configuration for all network requests -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system CAs -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Domain-specific configuration -->
    <domain-config cleartextTrafficPermitted="false">
        <!-- Your API domain -->
        <domain includeSubdomains="true">hungsanity.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
